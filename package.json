    "start": "next start",
    "lint": "eslint ."
  },
  "dependencies": {
    "@googleapis/sheets": "^13.0.2",
    "@heroui/accordion": "^2.2.19",
    "@strapi/blocks-react-renderer": "1.0.2",
    "@swc/helpers": "^0.5.17",
    "cheerio": "1.2.0",
    "cross-env": "^10.1.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.1",
    "google-auth-library": "^10.9.0",
    "gsap": "^3.13.0",
    "html-react-parser": "^5.2.10",
    "lottie-react": "^2.4.1",
    "next": "^16.2.3",
    "next-intl": "^4.3.4",
    "nodemailer": "^8.0.5",
    "qs": "^6.14.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hot-toast": "^2.5.2",
    "react-icons": "5.5.0",
    "react-intersection-observer": "^9.16.0",
    "server-only": "^0.0.1",
    "swiper": "12.1.2",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "0.1.0",
    "@tailwindcss/postcss": "^4",
    "autoprefixer": "^10.4.21",
    "eslint": "10.0.2",
    "eslint-config-next": "0.2.4",
    "husky": "9.1.7",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.10"
  }
