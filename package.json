{
  "name": "database_providers",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "gen:static-slugs": "node scripts/generate-static-page-slugs.mjs",
    "gen:llms-txt": "node scripts/generate-llms-txt.mjs",
    "predev": "npm run gen:static-slugs && npm run gen:llms-txt",
    "prebuild": "npm run gen:static-slugs && npm run gen:llms-txt",
    "dev": "next dev",
    "build": "next build",
